{
  "name": "kandi-agentic-forms",
  "version": "0.1.0",
  "description": "AI-powered conversational form filling — XML spec in, structured output files out",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/headless": {
      "types": "./dist/react/headless/index.d.ts",
      "import": "./dist/react/headless/index.js",
      "require": "./dist/react/headless/index.cjs"
    },
    "./react/mui": {
      "types": "./dist/react/mui/index.d.ts",
      "import": "./dist/react/mui/index.js",
      "require": "./dist/react/mui/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.0",
    "jose": "^5.10.0"
  },
  "peerDependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "kandi-login": "*",
    "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "kandi-login": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.3.1",
    "@mui/icons-material": "^7.3.1",
    "eslint": "^9.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "agentic",
    "forms",
    "ai",
    "conversational",
    "xml",
    "vercel-ai-sdk",
    "react",
    "sse",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KandiForge/kandi-packages.git",
    "directory": "packages/kandi-agentic-forms"
  },
  "homepage": "https://github.com/KandiForge/kandi-packages/tree/main/packages/kandi-agentic-forms#readme",
  "author": "KandiForge",
  "engines": {
    "node": ">=18.0.0"
  }
}
