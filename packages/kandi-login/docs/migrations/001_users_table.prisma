// kandi-login: Prisma schema for user table with OAuth provider linking
//
// Usage:
//   1. Copy this into your prisma/schema.prisma (or merge with existing)
//   2. Run: npx prisma migrate dev --name add-kandi-login-users
//   3. Implement UserAdapter using PrismaClient (see docs/examples.md)
//
// This uses a separate OAuthProvider join table instead of provider-specific
// columns. This is more normalized and works better with Prisma's relation model.

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  displayName   String?         @map("display_name")
  avatarUrl     String?         @map("avatar_url")
  emailVerified Boolean         @default(false) @map("email_verified")
  role          String          @default("user")
  providers     OAuthProvider[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model OAuthProvider {
  id             String @id @default(uuid())
  provider       String    // "google", "apple", "facebook", "hellocoop", "test"
  providerUserId String    @map("provider_user_id")
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_providers")
}
