{
  "name": "kandi-login",
  "version": "0.1.0",
  "description": "Universal OAuth login component for React — supports Tauri, Electron, and Web with MUI, Tailwind, or headless rendering",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/mui": {
      "types": "./dist/react/mui/index.d.ts",
      "import": "./dist/react/mui/index.js",
      "require": "./dist/react/mui/index.cjs"
    },
    "./react/headless": {
      "types": "./dist/react/headless/index.d.ts",
      "import": "./dist/react/headless/index.js",
      "require": "./dist/react/headless/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./tailwind/kandi-login.css": "./dist/tailwind/kandi-login.css"
  },
  "bin": {
    "kandi-login": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "tauri-plugin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && cp src/tailwind/kandi-login.css dist/tailwind/kandi-login.css",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.3.2",
    "jose": "^5.10.0",
    "open": "^10.1.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@mui/material": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@tauri-apps/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^9.0.0",
    "@mui/material": "^7.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "login",
    "oauth",
    "authentication",
    "react",
    "tauri",
    "electron",
    "mui",
    "tailwind",
    "apple-login",
    "google-login",
    "facebook-login",
    "hellocoop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KandiForge/kandi-packages",
    "directory": "packages/kandi-login"
  },
  "homepage": "https://github.com/KandiForge/kandi-packages/tree/main/packages/kandi-login#readme",
  "author": "KandiForge",
  "engines": {
    "node": ">=18.0.0"
  }
}
