# API server URL (for client-side calls when running separately)
NEXT_PUBLIC_API_URL=https://packages.kandiforge.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=generate-a-random-32-char-secret-here
JWT_ISSUER=packages.kandiforge.com

# OAuth Providers (optional — test personas work without these)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
HELLO_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# App URLs
BASE_URL=https://packages.kandiforge.com
SUCCESS_REDIRECT_URL=https://packages.kandiforge.com

# Test Personas
TEST_TOKEN_SECRET=generate-another-32-char-secret
